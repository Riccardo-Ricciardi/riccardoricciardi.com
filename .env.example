# ---------------------------------------------------------------------------
# riccardoricciardi.com — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# --- Supabase (public; safe to expose) -------------------------------------
# Project URL. Source: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/publishable key. Source: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public storage base URL for images (typically the storage object endpoint).
# Source: Supabase dashboard → Storage → Settings, or derived from the URL above.
NEXT_PUBLIC_SUPABASE_IMAGE_URL=https://your-project-ref.supabase.co/storage/v1/object/public

# --- Supabase (server-only; SECRET) ----------------------------------------
# Service-role key. Bypasses RLS — server only, never expose to the client.
# Source: Supabase dashboard → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Vercel cron (server-only; SECRET) -------------------------------------
# Shared bearer token between the Vercel cron, the Next.js API route, and the
# Supabase edge function. Generate a long random string (>= 32 chars).
CRON_SECRET=replace-with-long-random-string

# --- Admin gate (server-only) ----------------------------------------------
# Comma-separated list of emails allowed into /admin.
ADMIN_EMAILS=you@example.com,other@example.com

# --- Site metadata (public) ------------------------------------------------
# Canonical site origin. Used for OG, sitemap, absolute URLs.
NEXT_PUBLIC_SITE_URL=https://riccardoricciardi.com

# Comma-separated locale codes the build should ship.
NEXT_PUBLIC_LANGUAGES=en,it

# Default locale fallback when none matches the request.
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# --- Contact form (server-only; SECRET when set) ---------------------------
# Resend API key. Source: https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender (e.g. "Riccardo <hello@riccardoricciardi.com>").
RESEND_FROM=
# Inbox that receives form submissions.
RESEND_TO=

# Salt used to hash submitter IPs before storing them. Generate a random string.
CONTACT_IP_SALT=replace-with-random-string

# --- Cal.com booking (public + server) -------------------------------------
# Cal.com username. Source: cal.com/<username>.
NEXT_PUBLIC_CAL_USERNAME=
# Cal.com event slug under the username.
NEXT_PUBLIC_CAL_EVENT_SLUG=
# Cal.com API key for server-side availability lookups (optional).
CAL_API_KEY=

# --- Vercel auto-injected (do NOT set manually) ----------------------------
# VERCEL_OIDC_TOKEN — injected by Vercel CLI / runtime when needed.
